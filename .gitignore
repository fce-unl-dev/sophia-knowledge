# OS
.DS_Store
Thumbs.db

# Editores
.vscode/
.idea/
*.swp
*.swo

# Trabajos en progreso (drafts no listos para publicar)
/_drafts/

# Notas locales del mantenedor (no entran al KB que consume Sophia)
/_notas/

# Secrets locales del pipeline (GEMINI_API_KEY, etc.)
.env
.env.local
.env.*.local
tools/scraper/.env*

# Scraper dependencies and state
tools/scraper/node_modules/
# package-lock.json SÍ se trackea: ingest-drive.yml corre `npm ci`, que lo exige,
# y pinnea versiones exactas para builds reproducibles en CI.
# NOTA: NO ignorar tools/scraper/state/ en bloque. El .gitignore interno
# (tools/scraper/state/.gitignore) ignora los regenerables (raw.txt, candidate.md,
# gen.meta.json, catalog.json, candidates/) pero permite los *.meta.json chicos
# con hash, que DEBEN viajar en git para el diff-first del pipeline. Un blanket
# acá rompía `git add <slug>.meta.json` para slugs nuevos en los workflows.

